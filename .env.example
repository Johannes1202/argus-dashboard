# ── Proxmox ───────────────────────────────────────────────────────────────────
# Full URL to your Proxmox API (self-signed cert is fine — TLS is verified=false)
PROXMOX_API=https://192.168.1.10:8006/api2/json

# Node name as it appears in Proxmox (check: Datacenter > your node name)
PROXMOX_NODE=pve

# API token — create under Datacenter > Permissions > API Tokens
# Minimum required privileges: VM.Audit, Datastore.Audit, Sys.Audit
PROXMOX_TOKEN_ID=argus@pve!monitoring
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Proxmox Backup Server ─────────────────────────────────────────────────────
# Storage name as it appears in Proxmox (Datacenter > Storage)
# Leave blank or remove if you don't use PBS — the Backups tab will show empty.
PBS_STORAGE=PBS-Server

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Generate at https://login.tailscale.com/admin/settings/keys (read-only scoped key)
TAILSCALE_API_KEY=your-tailscale-api-key-here

# Your tailnet name — use "-" to auto-detect, or set explicitly (e.g. example.com)
TAILSCALE_TAILNET=-

# ── Pi-hole ───────────────────────────────────────────────────────────────────
# Requires Pi-hole v6+. Leave blank to disable Pi-hole stats.
PIHOLE_PRIMARY_URL=http://192.168.1.1
PIHOLE_FAILSAFE_URL=http://192.168.1.2
PIHOLE_PASSWORD=your-pihole-app-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Password to log in to the dashboard
DASHBOARD_PASSWORD=changeme

# Random string used to sign session cookies — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-string

# ── Optional ──────────────────────────────────────────────────────────────────
# Display name shown in the header and browser tab (default: Argus)
# APP_TITLE=Argus
